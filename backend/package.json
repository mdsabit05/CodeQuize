{
  "name": "app-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply app-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply app-db --remote",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/auth.ts --output src/schema.ts -y"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.7.10",
    "kysely": "^0.27.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.18.0"
  }
}
